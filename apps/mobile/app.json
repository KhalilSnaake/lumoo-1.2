{
  "expo": {
    "name": "Lumoo",
    "slug": "lumoo",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/fc31e4b2-89be-4aa9-84b0-866a6e8df670"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lumoo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "ml.lumoo.app"
    },
    "android": {
      "package": "ml.lumoo.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#A0C20C",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 165,
          "android": {
            "image": "./assets/images/splash-logo.png",
            "imageWidth": 165
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lumoo utilise votre position pour préciser le lieu de livraison."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#16a34a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc31e4b2-89be-4aa9-84b0-866a6e8df670"
      }
    },
    "owner": "pymalien"
  }
}
