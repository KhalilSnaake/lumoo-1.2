{
  "name": "lumoo-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "build:web": "npm run build --workspace apps/web",
    "test:core": "npm run test --workspace @lumoo/core"
  },
  "devDependencies": {
    "expo": "~54.0.0",
    "react-native": "^0.81.5"
  }
}
